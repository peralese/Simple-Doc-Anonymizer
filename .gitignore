# Python cache
__pycache__/
*.pyc
*.pyo

# Virtual environments
.env/
venv/
.venv/

# VSCode settings (optional)
.vscode/

# OS-specific files
.DS_Store
Thumbs.db

# Generated output files (keep the directories via .gitkeep)
output/*
!output/.gitkeep
doc-anonymizer-v2/output/*
!doc-anonymizer-v2/output/.gitkeep

# Archived / work-in-progress files
archive/

# Sensitive files
*.bak
*.tmp
*.old
